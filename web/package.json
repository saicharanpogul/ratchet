{
  "name": "ratchet-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web UI for ratchet — upgrade-safety checks for Solana programs",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/ratchet-wasm --target web --out-dir ../../web/lib/ratchet-wasm",
    "build:wasm:node": "wasm-pack build ../crates/ratchet-wasm --target nodejs --out-dir ../../web/lib/ratchet-wasm-node",
    "predev": "npm run build:wasm",
    "prebuild": "npm run build:wasm",
    "pretest": "npm run build:wasm:node",
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
